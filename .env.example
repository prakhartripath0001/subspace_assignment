# ──────────────────────────────────────────────────────────────────────────────
# Automated B2B Outreach Pipeline – Environment Variables
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Company Discovery – Apollo.io (REQUIRED) ─────────────────────────
# Get your key at: https://app.apollo.io/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here

# ── Stage 2: Contact Discovery – Prospeo (Optional) ───────────────────────────
# Get your key at: https://app.prospeo.io/api-settings
# Used for the /search-person endpoint (X-KEY header auth)
PROSPEO_API_KEY=your_prospeo_api_key_here

# ── Stage 3: Email Resolution – Eazyreach (Optional) ──────────────────────────
# OAuth 2.0 Client Credentials – get from your Eazyreach dashboard
# The service POSTs to https://api.eazyreach.io/oauth/token to obtain a token,
# then POSTs to https://api.eazyreach.io/v1/email/resolve per LinkedIn URL.
EAZYREACH_CLIENT_ID=your_eazyreach_client_id_here
EAZYREACH_CLIENT_SECRET=your_eazyreach_client_secret_here

# ── Stage 4: Email Outreach – Brevo (Optional) ────────────────────────────────
# Get your key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# ── Server Settings ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info                # debug | info | warn | error

# ── Email Sender Details ─────────────────────────────────────────────────────
SENDER_EMAIL=noreply@yourcompany.com
SENDER_NAME=Outreach Pipeline

# ── Feature Flags ─────────────────────────────────────────────────────────────
DRY_RUN=false                 # Set to true to run pipeline without sending emails
ENABLE_EMAIL_SENDING=true     # Set to false to disable Brevo sending globally
